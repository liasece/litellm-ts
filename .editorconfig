root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

[*.{ts,tsx,mjs,js}]
indent_style = tab
indent_size = 4
max_line_length = 140

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = tab
indent_size = 4

[{package.json,package-lock.json}]
indent_style = space
indent_size = 2
